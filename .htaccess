<IfModule mod_rewrite.c>
    RewriteEngine On

    # Browsers may request this conventional path even when the page links to
    # assets/images/favicon.ico.
    RewriteRule ^favicon\.ico$ assets/images/favicon.ico [L]

    # Let Apache serve real files/directories; send application URLs to CI.
    # Keeping PATH_INFO out of the substitution avoids 500 errors on hosts
    # where AcceptPathInfo is disabled.
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^ index.php [L,QSA]
</IfModule>
